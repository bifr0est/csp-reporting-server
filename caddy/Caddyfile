{
    # Caddy admin endpoint. Disabled for security.
    admin off
}

# Get domain name from environment variable, fallback to localhost
{$DOMAIN_NAME:-localhost} {

    # Rate limit CSP endpoint: 5 requests/sec (10 events per 2s), per IP
    rate_limit {
        zone csp {
            match {
                path /csp-report
            }
            key {remote_host}
            window 2s
            events 10
        }
    }

    route /csp-report {
        # IP allowlist for CSP endpoint - only allow configured web servers
        @allowed_web_servers {
            remote_ip {$CSP_ALLOWED_IPS:-127.0.0.1}
        }
        
        @post_csp_report {
            method POST
        }
        
        # Handle POST requests from allowed IPs
        handle @post_csp_report {
            reverse_proxy @allowed_web_servers http://csp-receiver:5000 {
                header_up Host {host}
                header_up X-Real-IP {remote_ip}
                header_up X-Forwarded-For {remote_ip}
                header_up X-Forwarded-Proto {scheme}
            }
            
            # Block POST requests from unauthorized IPs with 418 "I'm a teapot"
            respond * "I'm a teapot" 418 {
                close
            }
        }

        # For any other method (like GET) to /csp-report, return 418
        respond * 418 {
            close
        }
    }

    # Health check endpoint
    respond /health "OK" 200

    # Set security headers for all responses
    header {
        -Server
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-XSS-Protection "1; mode=block"
        # Strict-Transport-Security is often added automatically by Caddy
        # but can be specified here if needed.
    }

    # Reject all other requests
    respond "Not Found" 404
}